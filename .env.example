# ── Polymarket CLOB API ──────────────────────────────────────────────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=          # Polygon wallet private key (for signing)
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# ── Claude / Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Polygon / Web3 ───────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-bor-rpc.publicnode.com

# ── News APIs ────────────────────────────────────────────────────────
NEWSAPI_KEY=
TAVILY_API_KEY=

# ── Database ─────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./polymarket.db
# PostgreSQL (uncomment to use):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/polymarket

# ── App Settings ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
WHALE_WIN_RATE_THRESHOLD=0.80     # minimum win rate to track a wallet
WHALE_MIN_TRADES=10               # minimum trades before considering a wallet
CONFIDENCE_THRESHOLD=0.80         # minimum confidence to flag an opportunity
